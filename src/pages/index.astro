---
// Importación corregida (están en la misma carpeta)
import extensionsData from './data.json';

interface Extension {
  logo: string;
  name: string;
  description: string;
  isActive: boolean;
}

const extensions: Extension[] = extensionsData;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Gestor de Extensiones | Pro</title>
    <style is:global>
      :root {
        /* MODO OSCURO (Por defecto) */
        --bg-body: #0a0e1a;
        --bg-card: #1c2333;
        --bg-header: #151b28;
        --text-main: #ffffff;
        --text-muted: #94a3b8;
        --accent: #f43f5e; 
        --border: #2d3748;
        --icon-bg: #2d3748;
      }

      /* MODO CLARO (Se activa con la clase .light-mode) */
      body.light-mode {
        --bg-body: #f0f4f8;
        --bg-card: #ffffff;
        --bg-header: #ffffff;
        --text-main: #1a202c;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --icon-bg: #f1f5f9;
      }

      body {
        background-color: var(--bg-body);
        color: var(--text-main);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        margin: 0;
        padding: 0;
        min-height: 100vh;
        transition: background-color 0.3s, color 0.3s;
      }

      .container {
        max-width: 75rem;
        margin: 0 auto;
        padding: 2.5rem 1.25rem;
      }

      /* Navbar */
      .navbar {
        background-color: var(--bg-header);
        padding: 1rem 2rem;
        border-radius: 0.75rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        border: 1px solid var(--border);
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 700;
        font-size: 1.2rem;
      }

      .logo svg { width: 1.5rem; color: var(--accent); }

      /* Filtros */
      .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
      }

      .filter-group {
        background-color: var(--bg-header);
        padding: 0.35rem;
        border-radius: 0.75rem;
        display: flex;
        gap: 0.5rem;
        border: 1px solid var(--border);
      }

      .filter-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
      }

      .filter-btn.active {
        background-color: var(--accent);
        color: white;
      }

      /* Grid */
      .extension-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(18.75rem, 1fr));
        gap: 1.5rem;
      }

      .extension-card {
        background-color: var(--bg-card);
        border-radius: 1rem;
        padding: 1.5rem;
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.2s, background-color 0.3s;
      }

      .extension-card:hover { transform: translateY(-0.25rem); }

      .card-header { display: flex; gap: 1rem; }

      .icon-box {
        background-color: var(--icon-bg);
        width: 3.5rem; height: 3.5rem;
        border-radius: 0.75rem;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
      }

      .icon-box img { width: 2.2rem; height: 2.2rem; }

      .info h3 { margin: 0; font-size: 1.1rem; }
      .info p { color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0; line-height: 1.5; }

      .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 2rem;
      }

      .btn-action {
        background-color: rgba(148, 163, 184, 0.1);
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all 0.2s;
      }

      .btn-action:hover {
        color: var(--accent);
        border-color: var(--accent);
      }

      /* Switch */
      .switch {
        position: relative;
        display: inline-block;
        width: 2.8rem; height: 1.4rem;
      }

      .switch input { opacity: 0; width: 0; height: 0; }

      .slider {
        position: absolute; cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #4b5563;
        transition: 0.4s; border-radius: 1.5rem;
      }

      .slider:before {
        position: absolute; content: "";
        height: 1rem; width: 1rem;
        left: 0.2rem; bottom: 0.2rem;
        background-color: white; transition: 0.4s; border-radius: 50%;
      }

      input:checked + .slider { background-color: var(--accent); }
      input:checked + .slider:before { transform: translateX(1.4rem); }

      @media (max-width: 48rem) {
        .header-actions { flex-direction: column; gap: 1.5rem; align-items: flex-start; }
        .filter-group { width: 100%; justify-content: center; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <nav class="navbar">
        <div class="logo">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
          Extensiones
        </div>
        <button type="button" class="btn-action" id="theme-toggle">
          <span id="theme-icon">☀️</span> <span id="theme-text">Modo Claro</span>
        </button>
      </nav>

      <div class="header-actions">
        <h1 style="font-size: 2rem; margin: 0;">Lista de Extensiones</h1>
        <div class="filter-group">
          <button type="button" class="filter-btn active" data-filter="all">Todas</button>
          <button type="button" class="filter-btn" data-filter="active">Activas</button>
          <button type="button" class="filter-btn" data-filter="inactive">Inactivas</button>
        </div>
      </div>

      <main class="extension-grid">
        {extensions.map((ext) => (
          <article class="extension-card" data-active={ext.isActive.toString()}>
            <div class="card-header">
              <div class="icon-box">
                <img src={ext.logo.replace('./', '/')} alt="" />
              </div>
              <div class="info">
                <h3>{ext.name}</h3>
                <p>{ext.description}</p>
              </div>
            </div>
            
            <div class="card-footer">
              <button type="button" class="btn-action remove-btn">Eliminar</button>
              <label class="switch">
                <input type="checkbox" checked={ext.isActive} class="status-toggle" />
                <span class="slider"></span>
              </label>
            </div>
          </article>
        ))}
      </main>
    </div>

    <script>
      // 1. Lógica de Filtrado (En Español)
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.extension-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.getAttribute('data-filter');

          cards.forEach(card => {
            const isActive = card.getAttribute('data-active') === 'true';
            const htmlCard = card as HTMLElement;
            if (filter === 'all') {
              htmlCard.style.display = 'flex';
            } else if (filter === 'active' && isActive) {
              htmlCard.style.display = 'flex';
            } else if (filter === 'inactive' && !isActive) {
              htmlCard.style.display = 'flex';
            } else {
              htmlCard.style.display = 'none';
            }
          });
        });
      });

      // 2. Lógica de Cambio de Tema (Fix)
      const themeBtn = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      const themeText = document.getElementById('theme-text');

      themeBtn?.addEventListener('click', () => {
        document.body.classList.toggle('light-mode');
        const isLight = document.body.classList.contains('light-mode');
        
        if (themeIcon) themeIcon.innerText = isLight ? '🌙' : '☀️';
        if (themeText) themeText.innerText = isLight ? 'Modo Oscuro' : 'Modo Claro';
      });

      // 3. Eliminar
      document.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          (e.target as HTMLElement).closest('.extension-card')?.remove();
        });
      });

      // 4. Actualizar estado del switch
      document.querySelectorAll('.status-toggle').forEach(toggle => {
        toggle.addEventListener('change', (e) => {
          const input = e.target as HTMLInputElement;
          const card = input.closest('.extension-card') as HTMLElement;
          card.setAttribute('data-active', input.checked.toString());
        });
      });
    </script>
  </body>
</html>